-- Check if player is in any safe zone
function SafeZoneConfig:IsPlayerInSafeZone(player)
	if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
		return false, nil
	end

	local position = player.Character.HumanoidRootPart.Position
	local safeZonesFolder = workspace:FindFirstChild("SafeZones")

	if not safeZonesFolder then
		warn("SafeZones folder not found in Workspace!")
		return false, nil
	end

	for zoneID, zoneData in pairs(self.Zones) do
		if zoneData.IsUnlocked then
			local part = safeZonesFolder:FindFirstChild(zoneData.PartName)
			if part and part:IsA("BasePart") then
				if self:IsPositionInZone(position, part) then
					return true, zoneID
				end
			end
		end
	end

	return false, nil
end

-- Check if position is inside a safe zone part
function SafeZoneConfig:IsPositionInZone(position, zonePart)
	local relativePos = zonePart.CFrame:PointToObjectSpace(position)
	local halfSize = zonePart.Size / 2

	return math.abs(relativePos.X) <= halfSize.X and
		math.abs(relativePos.Y) <= halfSize.Y and
		math.abs(relativePos.Z) <= halfSize.Z
end

-- Check if zombie is in any safe zone
function SafeZoneConfig:IsZombieInSafeZone(zombie)
	if not zombie.PrimaryPart then return false end

	local position = zombie.PrimaryPart.Position
	local safeZonesFolder = workspace:FindFirstChild("SafeZones")

	if not safeZonesFolder then return false end

	for _, zoneData in pairs(self.Zones) do
		if zoneData.IsUnlocked then
			local part = safeZonesFolder:FindFirstChild(zoneData.PartName)
			if part and part:IsA("BasePart") then
				if self:IsPositionInZone(position, part) then
					return true
				end
			end
		end
	end

	return false
end

-- Check if position is valid for zombie spawning (not in/near safe zone)
function SafeZoneConfig:IsValidSpawnPosition(position)
	local safeZonesFolder = workspace:FindFirstChild("SafeZones")

	if not safeZonesFolder then return true end

	for _, zoneData in pairs(self.Zones) do
		if zoneData.IsUnlocked then
			local part = safeZonesFolder:FindFirstChild(zoneData.PartName)
			if part and part:IsA("BasePart") then
				-- Check if within safe zone + buffer
				local distance = (position - part.Position).Magnitude
				local maxDistance = (part.Size.Magnitude / 2) + self.Settings.SafeZoneSpawnBuffer

				if distance < maxDistance then
					return false -- Too close to safe zone
				end
			end
		end
	end

	return true
end

-- Unlock a safe zone
function SafeZoneConfig:UnlockZone(zoneID)
	if self.Zones[zoneID] then
		self.Zones[zoneID].IsUnlocked = true
		return true
	end
	return false
end

-- Get all unlocked zones
function SafeZoneConfig:GetUnlockedZones()
	local unlocked = {}
	for zoneID, zoneData in pairs(self.Zones) do
		if zoneData.IsUnlocked then
			table.insert(unlocked, {ID = zoneID, Data = zoneData})
		end
	end
	return unlocked
end

return SafeZoneConfig
