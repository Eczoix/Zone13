-- FallDamage (LocalScript > StarterCharacterScripts)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local fallDamageEvent = ReplicatedStorage:WaitForChild("GameRemotes"):WaitForChild("FallDamageEvent")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Config
local MIN_FALL_DISTANCE = 10
local DAMAGE_MULTIPLIER = 0.8
local MAX_DAMAGE = 100

local peakHeight = nil
local isFalling = false

RunService.Heartbeat:Connect(function()
	if not humanoid or humanoid.Health <= 0 then return end

	local floorMaterial = humanoid.FloorMaterial

	if floorMaterial == Enum.Material.Air then
		if not isFalling then
			isFalling = true
			peakHeight = rootPart.Position.Y
		else
			if rootPart.Position.Y > peakHeight then
				peakHeight = rootPart.Position.Y
			end
		end
	else
		if isFalling and peakHeight then
			local fallDistance = peakHeight - rootPart.Position.Y

			if fallDistance >= MIN_FALL_DISTANCE then
				local damage = math.floor((fallDistance - MIN_FALL_DISTANCE) * DAMAGE_MULTIPLIER)
				damage = math.clamp(damage, 0, MAX_DAMAGE)

				if damage > 0 then
					fallDamageEvent:FireServer(damage)
				end
			end
		end

		isFalling = false
		peakHeight = nil
	end
end)

humanoid.Died:Connect(function()
	isFalling = false
	peakHeight = nil
end)
