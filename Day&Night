-- NEW DAY/NIGHT CYCLE SYSTEM
local DAY_LENGTH = 5 * 60 -- 5 minutes in seconds
local MINUTES_IN_DAY = 24 * 60
local START_HOUR = 7 -- Start at 12 PM (noon)

-- Calculate starting offset so we begin at 12 PM
-- 12 PM = 720 minutes = 50% through a 24-hour day
local startProgress = (START_HOUR * 60) / MINUTES_IN_DAY -- 0.5 for noon
GlobalState.gameStartTime = tick() - (startProgress * DAY_LENGTH)
GlobalState.DAY_LENGTH = DAY_LENGTH

-- Set initial ClockTime to noon
Lighting:SetMinutesAfterMidnight(START_HOUR * 60)
TimeManager.lastNightState = false

-- Main update loop
RunService.Heartbeat:Connect(function(deltaTime)
	-- Calculate cycle progress (0 to 1)
	local elapsed = (tick() - GlobalState.gameStartTime) % DAY_LENGTH
	local progress = elapsed / DAY_LENGTH

	-- Update Lighting ClockTime for sun movement
	local gameMinutes = progress * MINUTES_IN_DAY
	Lighting:SetMinutesAfterMidnight(gameMinutes)

	-- Update game state logic
	TimeManager:Update()
end)

