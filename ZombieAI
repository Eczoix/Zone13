-- Get update interval based on distance to nearest player
local function getUpdateInterval(zombiePosition)
	local nearestDistance = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local distance = (player.Character.HumanoidRootPart.Position - zombiePosition).Magnitude
			if distance < nearestDistance then
				nearestDistance = distance
			end
		end
	end

	-- Return appropriate update interval
	if nearestDistance < NEAR_DISTANCE then
		return NEAR_UPDATE_INTERVAL -- Every frame (instant)
	elseif nearestDistance < FAR_DISTANCE then
		return FAR_UPDATE_INTERVAL -- Every 2 seconds
	else
		return VERY_FAR_UPDATE_INTERVAL -- Every 5 seconds
	end
end

-- Get nearest player to zombie
local function getNearestPlayer(zombiePosition)
	local nearestPlayer = nil
	local nearestDistance = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character then
			local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
			local rootPart = player.Character:FindFirstChild("HumanoidRootPart")

			if humanoid and rootPart and humanoid.Health > 0 then
				-- Check if player is in safe zone
				local inSafeZone = _G.IsPlayerInSafeZone and _G.IsPlayerInSafeZone(player)

				if not inSafeZone then
					local distance = (rootPart.Position - zombiePosition).Magnitude

					if distance < nearestDistance then
						nearestDistance = distance
						nearestPlayer = player
					end
				end
			end
		end
	end

	return nearestPlayer, nearestDistance
end

-- Predict where target will be
local function predictTargetPosition(targetRoot, distance)
	if not targetRoot then return nil end

	-- Get target's velocity
	local velocity = targetRoot.AssemblyLinearVelocity

	-- Calculate how long it takes zombie to reach target
	local timeToReach = distance / 16 -- Assuming average zombie speed of 16

	-- Predict future position
	local predictedPosition = targetRoot.Position + (velocity * timeToReach * PREDICTION_MULTIPLIER)

	return predictedPosition
end

-- Get random roam position near zombie
local function getRandomRoamPosition(zombiePosition)
	-- Random angle
	local angle = math.random() * math.pi * 2

	-- Random distance (much shorter for realistic shambling)
	local distance = math.random(ROAM_MIN_DISTANCE, ROAM_MAX_DISTANCE)

	-- Calculate position
	local offsetX = math.cos(angle) * distance
	local offsetZ = math.sin(angle) * distance

	local roamPosition = zombiePosition + Vector3.new(offsetX, 0, offsetZ)

	return roamPosition
end

-- Check if there's a clear line of sight
local function hasLineOfSight(fromPosition, toPosition)
	local direction = (toPosition - fromPosition)
	local distance = direction.Magnitude

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude

	-- Build filter list with only existing folders
	local filterList = {}
	if workspace:FindFirstChild("Zombies") then
		table.insert(filterList, workspace.Zombies)
	end
	if workspace:FindFirstChild("Effects") then
		table.insert(filterList, workspace.Effects)
	end

	rayParams.FilterDescendantsInstances = filterList

	local result = workspace:Raycast(fromPosition, direction.Unit * distance, rayParams)

	-- If no hit or hit is far away, we have line of sight
	return result == nil or result.Distance > (distance - 5)
end

