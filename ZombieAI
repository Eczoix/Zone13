-- Direct movement (for close range)
local function moveDirectly(zombie, targetPosition, humanoid, state)
	if not zombie.PrimaryPart then return end

	local currentTime = tick()
	local JUMP_COOLDOWN = 1.5 -- Can only jump once every 1.5 seconds

	-- Check for obstacles in front
	local zombiePos = zombie.PrimaryPart.Position
	local direction = (targetPosition - zombiePos).Unit
	local checkDistance = 5 -- Check 5 studs ahead

	-- Raycast forward at chest height
	local rayOrigin = zombiePos + Vector3.new(0, 2, 0)
	local rayDirection = direction * checkDistance

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude

	local filterList = {zombie}
	if workspace:FindFirstChild("Zombies") then
		table.insert(filterList, workspace.Zombies)
	end
	rayParams.FilterDescendantsInstances = filterList

	local result = workspace:Raycast(rayOrigin, rayDirection, rayParams)

	-- If we hit something, check if we can jump over it
	if result then
		local hitPart = result.Instance

		-- Check if obstacle is jumpable (small obstacles)
		if hitPart and hitPart:IsA("BasePart") then
			local obstacleHeight = hitPart.Size.Y

			-- If obstacle is between 2-6 studs tall, try jumping (with cooldown)
			if obstacleHeight >= 2 and obstacleHeight <= 6 then
				if currentTime - state.lastJump >= JUMP_COOLDOWN then
					humanoid.Jump = true
					state.lastJump = currentTime
				end
			end
		end
	end

	-- Use predicted position for more responsive movement
	local distance = (zombie.PrimaryPart.Position - targetPosition).Magnitude
	local predictedPos = predictTargetPosition(state.targetRoot, distance)

	if predictedPos then
		humanoid:MoveTo(predictedPos)
	else
		humanoid:MoveTo(targetPosition)
	end

	state.movementMode = "Direct"
end

-- Pathfinding movement (for long range or obstacles)
local function moveWithPathfinding(zombie, targetPosition, humanoid, state)
	local currentTime = tick()

	-- Don't recalculate path too often
	if state.lastPathCalc and (currentTime - state.lastPathCalc) < PATH_UPDATE_INTERVAL then
		return
	end

	state.lastPathCalc = currentTime

	-- Create path
	local path = PathfindingService:CreatePath(pathParams)

	local success = pcall(function()
		path:ComputeAsync(zombie.PrimaryPart.Position, targetPosition)
	end)

	if success and path.Status == Enum.PathStatus.Success then
		local waypoints = path:GetWaypoints()

		if #waypoints > 0 then
			-- Only move to next few waypoints (more responsive)
			local targetWaypoint = waypoints[math.min(3, #waypoints)]

			if targetWaypoint.Action == Enum.PathWaypointAction.Jump then
				humanoid.Jump = true
			end

			humanoid:MoveTo(targetWaypoint.Position)
			state.movementMode = "Pathfinding"
		end
	else
		-- Pathfinding failed, try direct movement
		moveDirectly(zombie, targetPosition, humanoid, state)
	end
end

-- Smart movement decision
local function moveToTarget(zombie, targetRoot, humanoid, state, distance)
	if not zombie.PrimaryPart or not targetRoot then return end

	local zombiePos = zombie.PrimaryPart.Position
	local targetPos = targetRoot.Position

	-- CLOSE RANGE: Direct movement (responsive and fast)
	if distance < CLOSE_RANGE_DISTANCE then
		moveDirectly(zombie, targetPos, humanoid, state)
		return
	end

	-- MEDIUM/FAR RANGE: Check line of sight
	if hasLineOfSight(zombiePos, targetPos) then
		-- Clear path - use direct movement
		moveDirectly(zombie, targetPos, humanoid, state)
	else
		-- Obstacles in the way - use pathfinding
		moveWithPathfinding(zombie, targetPos, humanoid, state)
	end
end

-- Roaming behavior when idle (Dying Light style)
local function roamAround(zombie, humanoid, state)
	if not zombie.PrimaryPart then return end

	local currentTime = tick()

	-- Initialize roaming state
	if not state.roamState then
		state.roamState = "pausing"
		state.roamStateStartTime = currentTime
		state.roamPauseDuration = math.random(ROAM_PAUSE_MIN, ROAM_PAUSE_MAX)
		humanoid:MoveTo(zombie.PrimaryPart.Position) -- Stop moving
	end

	-- PAUSING STATE (standing still, looking around)
	if state.roamState == "pausing" then
		local pauseElapsed = currentTime - state.roamStateStartTime

		-- Set walk speed to 0 during pause
		humanoid.WalkSpeed = 0
		humanoid:MoveTo(zombie.PrimaryPart.Position)

		-- Play idle animation
		playAnimation(zombie, "Idle")

		-- Pause time over, start walking
		if pauseElapsed >= state.roamPauseDuration then
			state.roamState = "walking"
			state.roamStateStartTime = currentTime
			state.roamWalkDuration = math.random(ROAM_WALK_TIME_MIN, ROAM_WALK_TIME_MAX)
			state.roamTarget = getRandomRoamPosition(zombie.PrimaryPart.Position)

			-- Set slow walk speed from config (WalkSpeed, not ChaseSpeed!)
			humanoid.WalkSpeed = state.stats.WalkSpeed
		end

		-- WALKING STATE (slow shambling)
	elseif state.roamState == "walking" then
		local walkElapsed = currentTime - state.roamStateStartTime

		-- Make sure speed is set to WalkSpeed from config
		if humanoid.WalkSpeed ~= state.stats.WalkSpeed then
			humanoid.WalkSpeed = state.stats.WalkSpeed
			print("Setting zombie walk speed to:", state.stats.WalkSpeed) -- DEBUG
		end

		-- Play roam walk animation
		playAnimation(zombie, "RoamWalk")

		-- Check if reached roam target or walk time expired
		local reachedTarget = false
		if state.roamTarget then
			local distanceToRoam = (zombie.PrimaryPart.Position - state.roamTarget).Magnitude

			local JUMP_COOLDOWN = 1.5

			-- Check for obstacles while roaming
			local direction = (state.roamTarget - zombie.PrimaryPart.Position).Unit
			local rayOrigin = zombie.PrimaryPart.Position + Vector3.new(0, 2, 0)
			local rayDirection = direction * 5

			local rayParams = RaycastParams.new()
			rayParams.FilterType = Enum.RaycastFilterType.Exclude
			local filterList = {zombie}
			if workspace:FindFirstChild("Zombies") then
				table.insert(filterList, workspace.Zombies)
			end
			rayParams.FilterDescendantsInstances = filterList

			local result = workspace:Raycast(rayOrigin, rayDirection, rayParams)

			-- Jump over small obstacles (with cooldown)
			if result and result.Instance:IsA("BasePart") then
				local obstacleHeight = result.Instance.Size.Y
				if obstacleHeight >= 2 and obstacleHeight <= 6 then
					if currentTime - state.lastJump >= JUMP_COOLDOWN then
						humanoid.Jump = true
						state.lastJump = currentTime
					end
				end
			end

			-- DEBUG: Print zombie status
			if math.random() < 0.01 then -- Print occasionally to avoid spam
				print(zombie.Name, "walking - Speed:", humanoid.WalkSpeed, "Distance to target:", math.floor(distanceToRoam))
			end

			if distanceToRoam < 3 then
				reachedTarget = true
			else
				-- Keep walking to target
				humanoid:MoveTo(state.roamTarget)
			end
		end

		-- Time to pause again
		if walkElapsed >= state.roamWalkDuration or reachedTarget then
			state.roamState = "pausing"
			state.roamStateStartTime = currentTime
			state.roamPauseDuration = math.random(ROAM_PAUSE_MIN, ROAM_PAUSE_MAX)
			state.roamTarget = nil
			humanoid:MoveTo(zombie.PrimaryPart.Position)
		end
	end
end

