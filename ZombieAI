-- Performance settings
local CLOSE_RANGE_DISTANCE = 30 -- Within this range, use direct movement
local PATH_UPDATE_INTERVAL = 1.5 -- Only recalc path every 1.5 seconds for distant targets
local PREDICTION_MULTIPLIER = 0.8 -- Predict target's future position

-- AI Update Throttling (Performance optimization)
local NEAR_DISTANCE = 80 -- Update every frame (instant reactions in combat)
local FAR_DISTANCE = 150 -- Update every 2 seconds (medium distance)
local VERY_FAR_DISTANCE = 200 -- Update every 5 seconds (distant zombies)

local NEAR_UPDATE_INTERVAL = 0 -- Every frame for close zombies
local FAR_UPDATE_INTERVAL = 2 -- 2 seconds for far zombies
local VERY_FAR_UPDATE_INTERVAL = 5 -- 5 seconds for very far zombies

-- Roaming settings (Dying Light style)
local ROAM_MIN_DISTANCE = 8 -- Minimum roam distance
local ROAM_MAX_DISTANCE = 20 -- Maximum roam distance (shorter than before)
local ROAM_PAUSE_MIN = 2 -- Minimum pause time between roams
local ROAM_PAUSE_MAX = 6 -- Maximum pause time between roams
local ROAM_WALK_TIME_MIN = 3 -- Minimum time spent walking to a spot
local ROAM_WALK_TIME_MAX = 8 -- Maximum time spent walking

