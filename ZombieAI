-- Default Roblox animation IDs (placeholders)
local DEFAULT_ANIMATIONS = {
	Idle = "rbxassetid://507766388",      -- Default idle
	Walk = "rbxassetid://507777826",      -- Default walk
	Run = "rbxassetid://507767714",       -- Default run
	Attack = "rbxassetid://507768133",    -- Default slash/punch
}

-- Animation states
local zombieAnimations = {}

-- Load animations for a zombie
local function loadAnimations(zombie, zombieType)
	local humanoid = zombie:FindFirstChildOfClass("Humanoid")
	if not humanoid then return nil end

	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		animator = Instance.new("Animator")
		animator.Parent = humanoid
	end

	-- Get animation IDs from config (or use defaults)
	local stats = ZombieConfig:GetZombieStats(zombieType)
	local animIds = stats.Animations or {}

	-- Create animation tracks
	local animations = {
		Idle = nil,
		RoamWalk = nil,
		Chase = nil,
		Attack = nil,

		currentTrack = nil,
		currentState = "Idle"
	}

	-- Load Idle animation
	local idleAnim = Instance.new("Animation")
	idleAnim.AnimationId = animIds.Idle or DEFAULT_ANIMATIONS.Idle
	animations.Idle = animator:LoadAnimation(idleAnim)
	animations.Idle.Looped = true
	animations.Idle.Priority = Enum.AnimationPriority.Idle

	-- Load Roam Walk animation
	local roamWalkAnim = Instance.new("Animation")
	roamWalkAnim.AnimationId = animIds.RoamWalk or DEFAULT_ANIMATIONS.Walk
	animations.RoamWalk = animator:LoadAnimation(roamWalkAnim)
	animations.RoamWalk.Looped = true
	animations.RoamWalk.Priority = Enum.AnimationPriority.Movement

	-- Load Chase animation
	local chaseAnim = Instance.new("Animation")
	chaseAnim.AnimationId = animIds.Chase or DEFAULT_ANIMATIONS.Run
	animations.Chase = animator:LoadAnimation(chaseAnim)
	animations.Chase.Looped = true
	animations.Chase.Priority = Enum.AnimationPriority.Movement

	-- Load Attack animation
	local attackAnim = Instance.new("Animation")
	attackAnim.AnimationId = animIds.Attack or DEFAULT_ANIMATIONS.Attack
	animations.Attack = animator:LoadAnimation(attackAnim)
	animations.Attack.Looped = false
	animations.Attack.Priority = Enum.AnimationPriority.Action

	return animations
end

-- Play animation with smooth transition
local function playAnimation(zombie, animationName)
	local animData = zombieAnimations[zombie]
	if not animData then 
		warn("No animation data for zombie:", zombie.Name)
		return 
	end

	local targetTrack = animData[animationName]
	if not targetTrack then 
		warn("Animation not found:", animationName, "for zombie:", zombie.Name)
		return 
	end

	-- Don't replay if already playing
	if animData.currentState == animationName and targetTrack.IsPlaying then
		return
	end

	-- Stop current animation
	if animData.currentTrack and animData.currentTrack.IsPlaying then
		animData.currentTrack:Stop(0.2) -- Smooth 0.2s fade out
	end

	-- Play new animation
	targetTrack:Play(0.2) -- Smooth 0.2s fade in
	animData.currentTrack = targetTrack
	animData.currentState = animationName

	print("Playing animation:", animationName, "for", zombie.Name, "Priority:", targetTrack.Priority) -- DEBUG
end

-- Stop all animations
local function stopAllAnimations(zombie)
	local animData = zombieAnimations[zombie]
	if not animData then return end

	for name, track in pairs(animData) do
		if type(track) == "userdata" and track.IsPlaying then
			track:Stop(0.2)
		end
	end

	animData.currentTrack = nil
	animData.currentState = "Idle"
end

