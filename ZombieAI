-- Check if zombie can attack target
local function canAttack(zombie, target, stats)
	if not target or not target.Parent then return false end

	local zombieRoot = zombie.PrimaryPart
	local targetRoot = target:FindFirstChild("HumanoidRootPart")

	if not zombieRoot or not targetRoot then return false end

	-- Check distance
	local distance = (zombieRoot.Position - targetRoot.Position).Magnitude
	if distance > stats.AttackRange then
		return false
	end

	-- Check line of sight (can't attack through walls)
	local rayOrigin = zombieRoot.Position + Vector3.new(0, 2, 0) -- From zombie's chest
	local rayDirection = (targetRoot.Position - rayOrigin)

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude

	-- Build filter list
	local filterList = {zombie}
	if workspace:FindFirstChild("Zombies") then
		table.insert(filterList, workspace.Zombies)
	end
	if workspace:FindFirstChild("Effects") then
		table.insert(filterList, workspace.Effects)
	end

	rayParams.FilterDescendantsInstances = filterList

	local result = workspace:Raycast(rayOrigin, rayDirection, rayParams)

	-- If raycast hit something before reaching player, can't attack
	if result then
		-- Check if we hit the player or something else
		local hitCharacter = result.Instance:FindFirstAncestorOfClass("Model")
		if hitCharacter ~= target then
			return false -- Hit a wall or obstacle
		end
	end

	return true
end

-- Lunge forward during attack
local function lungeAtTarget(zombie, targetPosition)
	local rootPart = zombie.PrimaryPart
	if not rootPart then return end

	-- Play attack animation
	playAnimation(zombie, "Attack")

	-- Calculate lunge direction
	local direction = (targetPosition - rootPart.Position).Unit
	local lungeDistance = 4 -- Lunge 4 studs forward

	-- Create temporary velocity to push zombie forward
	local bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.Velocity = direction * 30 -- Speed of lunge
	bodyVelocity.MaxForce = Vector3.new(4000, 0, 4000) -- Only horizontal movement
	bodyVelocity.Parent = rootPart

	-- Remove after 0.2 seconds
	task.delay(0.2, function()
		if bodyVelocity and bodyVelocity.Parent then
			bodyVelocity:Destroy()
		end
	end)
end

-- Perform attack on player
local function attackPlayer(zombie, target, stats, state)
	-- Check attack cooldown
	local currentTime = tick()
	if currentTime - state.lastAttack < stats.AttackCooldown then
		return
	end

	local targetRoot = target:FindFirstChild("HumanoidRootPart")
	if not targetRoot then return end

	-- Lunge forward
	lungeAtTarget(zombie, targetRoot.Position)

	-- Delay damage slightly so lunge connects first
	task.delay(0.15, function()
		if not target or not target.Parent then return end

		local targetHumanoid = target:FindFirstChildOfClass("Humanoid")
		if targetHumanoid and targetHumanoid.Health > 0 then
			targetHumanoid:TakeDamage(stats.Damage)
		end
	end)

	state.lastAttack = currentTime
end

