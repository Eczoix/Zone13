-- Initialize zombie AI state
local function initializeZombieAI(zombie)
	if not zombie:IsA("Model") then return end

	local humanoid = zombie:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local rootPart = zombie.PrimaryPart or zombie:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	if not zombie.PrimaryPart then
		zombie.PrimaryPart = rootPart
	end

	-- CRITICAL: Unanchor all parts so zombie can move
	rootPart.Anchored = false
	for _, part in pairs(zombie:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Anchored = false
		end
	end

	-- Get zombie stats
	local stats = ZombieConfig:GetZombieStats(zombie.Name)
	if not stats then 
		for typeName, _ in pairs(ZombieConfig.ZombieTypes) do
			if string.find(zombie.Name, typeName) then
				stats = ZombieConfig:GetZombieStats(typeName)
				break
			end
		end

		if not stats then
			stats = ZombieConfig:GetZombieStats("Walker")
			if not stats then return end
		end
	end

	-- Initialize state
	zombieStates[zombie] = {
		stats = stats,
		target = nil,
		targetRoot = nil,
		lastAttack = 0,
		lastPathCalc = 0,
		lastUpdate = 0, -- For throttling updates
		lastJump = 0,   -- For jump cooldown
		state = "Idle",
		movementMode = "None",

		-- Roaming (Dying Light style)
		roamState = nil, -- "pausing" or "walking"
		roamStateStartTime = 0,
		roamPauseDuration = 0,
		roamWalkDuration = 0,
		roamTarget = nil,
	}

	-- Load animations
	local animations = loadAnimations(zombie, zombie.Name)
	if animations then
		zombieAnimations[zombie] = animations
		-- Start with idle animation
		playAnimation(zombie, "Idle")
	end

	table.insert(updateQueue, zombie)
end

-- Main AI update
local function updateZombieAI(zombie)
	if not zombie or not zombie.Parent then 
		zombieStates[zombie] = nil
		return 
	end

	local state = zombieStates[zombie]
	if not state then return end

	local humanoid = zombie:FindFirstChildOfClass("Humanoid")
	local rootPart = zombie.PrimaryPart

	if not humanoid or not rootPart or humanoid.Health <= 0 then
		return
	end

	local stats = state.stats

	-- Find nearest player
	local nearestPlayer, distance = getNearestPlayer(rootPart.Position)

	-- No players nearby
	if not nearestPlayer then
		state.state = "Idle"
		state.target = nil
		state.targetRoot = nil
		roamAround(zombie, humanoid, state) -- Roam instead of standing still
		return
	end

	-- Player too far
	if distance > stats.DetectionRange then
		state.state = "Idle"
		state.target = nil
		state.targetRoot = nil
		roamAround(zombie, humanoid, state) -- Roam instead of standing still
		return
	end

	-- Player detected! Stop roaming
	state.roamTarget = nil
	state.roamState = nil -- Reset roaming behavior

	-- Safety check - player might have left
	if not nearestPlayer or not nearestPlayer.Character then
		state.state = "Idle"
		state.target = nil
		state.targetRoot = nil
		roamAround(zombie, humanoid, state)
		return
	end

	state.target = nearestPlayer.Character
	state.targetRoot = state.target:FindFirstChild("HumanoidRootPart")

	if not state.targetRoot then return end

	-- Set correct speed
	if humanoid.WalkSpeed ~= stats.ChaseSpeed then
		humanoid.WalkSpeed = stats.ChaseSpeed
	end

	-- ATTACK MODE
	if canAttack(zombie, state.target, stats) then
		state.state = "Attacking"
		humanoid:MoveTo(rootPart.Position) -- Stop moving
		attackPlayer(zombie, state.target, stats, state)
		return
	end

	-- CHASE MODE
	state.state = "Chasing"

	-- Play chase animation
	playAnimation(zombie, "Chase")

	moveToTarget(zombie, state.targetRoot, humanoid, state, distance)
end

