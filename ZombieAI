	if zombieStates[instance] then
		-- Stop all animations
		stopAllAnimations(instance)

		zombieStates[instance] = nil
		zombieAnimations[instance] = nil

		for i, zombie in ipairs(updateQueue) do
			if zombie == instance then
				table.remove(updateQueue, i)
				break
			end
		end
	end
end)

