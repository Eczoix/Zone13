RunService.Heartbeat:Connect(function()
	if #updateQueue == 0 then return end

	local currentTime = tick()

	-- Process one zombie per frame (staggered updates)
	local zombie = updateQueue[updateIndex]

	if zombie and zombie.Parent then
		local state = zombieStates[zombie]
		if state then
			local rootPart = zombie.PrimaryPart

			if rootPart then
				-- Determine update interval based on distance
				local updateInterval = getUpdateInterval(rootPart.Position)

				-- Check if enough time has passed since last update
				if currentTime - state.lastUpdate >= updateInterval then
					state.lastUpdate = currentTime
					updateZombieAI(zombie)
				end
			end
		end
	else
		-- Zombie is gone, remove from queue
		table.remove(updateQueue, updateIndex)
		updateIndex = updateIndex - 1
	end

	-- Move to next zombie
	updateIndex = updateIndex + 1
	if updateIndex > #updateQueue then
		updateIndex = 1
	end
end)

