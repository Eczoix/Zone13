local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- Wait for GlobalState module
local GlobalState = require(ReplicatedStorage:WaitForChild("GlobalState"))
GlobalState:InitializeRemotes()

-- Get remote events
local remotes = ReplicatedStorage:WaitForChild("GameRemotes")
local weatherChangeRemote = remotes:WaitForChild("WeatherChange")
local gameStateRequestRemote = remotes:WaitForChild("GameStateRequest")

local WeatherManager = {
	currentWeather = "Clear",
	updateInterval = 0
}

-- Change weather and notify all clients
function WeatherManager:ChangeWeather(newWeather)
	if not newWeather then
		newWeather = GlobalState:GetRandomWeather()
	end

	-- Don't change if it's the same weather
	if newWeather == self.currentWeather then
		return
	end

	self.currentWeather = newWeather
	GlobalState.currentWeather = newWeather
	GlobalState.lastWeatherChange = tick()

	local weatherData = GlobalState:GetWeatherData(newWeather)

	print("[WeatherManager] " .. weatherData.icon .. " Weather changed to: " .. newWeather)

	-- Notify all clients
	weatherChangeRemote:FireAllClients({
		weather = newWeather,
		weatherData = weatherData
	})
end

-- Update weather system
function WeatherManager:Update()
	-- Check if it's time to change weather
	if GlobalState:ShouldChangeWeather() then
		self:ChangeWeather()
	end
end

-- Handle client requests for game state (include weather)
local oldGameStateHandler = gameStateRequestRemote.OnServerEvent
gameStateRequestRemote.OnServerEvent:Connect(function(player)
	-- Send weather state along with game state
	weatherChangeRemote:FireClient(player, {
		weather = WeatherManager.currentWeather,
		weatherData = GlobalState:GetWeatherData(WeatherManager.currentWeather)
	})
end)

-- Initialize with clear weather
WeatherManager:ChangeWeather("Clear")

-- Main update loop (runs every second)
RunService.Heartbeat:Connect(function(deltaTime)
	WeatherManager.updateInterval = WeatherManager.updateInterval + deltaTime

	if WeatherManager.updateInterval >= 1 then
		WeatherManager.updateInterval = 0
		WeatherManager:Update()
	end
end)

print("[WeatherManager] System started - Weather: " .. WeatherManager.currentWeather)
