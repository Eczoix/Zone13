-- ═══════════════════════════════════════════════════════════════
--                       PUBLIC FUNCTIONS
-- ═══════════════════════════════════════════════════════════════

function SendNotificationToAll(preset, ...)
	local data = NotificationPresets[preset](...)
	if data then
		notificationRemote:FireAllClients(data)
		print("📢 Sent notification: " .. preset)
	end
end

_G.SendNotificationToAll = SendNotificationToAll

print("✅ Notification Server initialized!")
