-- 📢 NOTIFICATION SERVER
-- Sends notifications to players for game events

local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Wait for remotes
local remotes = ReplicatedStorage:WaitForChild("GameRemotes")

-- Create notification remote
local notificationRemote = remotes:FindFirstChild("ShowNotification")
if not notificationRemote then
	notificationRemote = Instance.new("RemoteEvent")
	notificationRemote.Name = "ShowNotification"
	notificationRemote.Parent = remotes
	print("✅ Created ShowNotification remote")
end

